# Godot 4+ — editor cache, imported assets, local editor state
.godot/

# Godot 3 legacy import folder (harmless if absent)
.import/

# Export configuration with secrets (commit export_presets.cfg; not credentials)
export_credentials.cfg

# Transient / backup files
*.tmp
*~

# Imported translations generated from CSV
*.translation

# C# / Mono (not used by this project; safe to keep)
.mono/
data_*/
mono_crash.*.json

# -----------------------------------------------------------------------------
# Export build outputs (regenerated by Export)
# -----------------------------------------------------------------------------
/android/
/ios/
/web/
/linux/
/windows/
/macOS/
*.apk
*.aab
*.ipa
*.exe
*.x86_64
*.dmg
*.app

# -----------------------------------------------------------------------------
# Local SQLite databases (godot-sqlite / dev & test data)
# Runtime data should use user://; ignore accidental project copies.
# Does not affect addons/godot-sqlite/ (native libs stay tracked).
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
*.db-journal
*.db-wal
*.db-shm
/data/
/user_data/

# -----------------------------------------------------------------------------
# OS & editor tooling
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.code-workspace

# Godot-specific: ignore .nomedia on Android export folders
.nomedia
